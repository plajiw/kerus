{
  "name": "kerus",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && vitepress build docs && shx mkdir -p dist/docs && shx cp -r docs/.vitepress/dist/* dist/docs/",
    "preview": "vite preview",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:copy": "vitepress build docs && shx mkdir -p public/docs && shx cp -r docs/.vitepress/dist/* public/docs/",
    "build:all": "npm run build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^1.38.0",
    "lucide-react": "^0.563.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "shx": "^0.4.0",
    "typescript": "~5.8.2",
    "vite": "^6.4.1",
    "vitepress": "^1.6.3"
  }
}
